          "label": "Image 2 (Mobile)",
          "info": "Select the mobile version of the second top-level image."
        },
        {
          "type": "text",
          "id": "title_2",
          "label": "Title 2",
          "info": "Title for the second top-level link."
        },
        {
          "type": "text",
          "id": "icon_2",
          "label": "Icon 2",
          "info": "Icon for the second link."
        },
        {
          "type": "url",
          "id": "url_2",
          "label": "Link 2",
          "info": "URL for the second top-level link."
        },
        {
          "type": "text",
          "id": "button_text_2",
          "label": "Button Text 2",
          "info": "Text for the second top-level button."
        },
        {
          "type": "text",
          "id": "button_text_style_2",
          "label": "Button Style 2",
          "default": "b2",
          "info": "Style for the second top-level button."
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3",
          "info": "Select the third top-level image."
        },
        {
          "type": "image_picker",
          "id": "mobile_image_3",
          "label": "Image 3 (Mobile)",
          "info": "Select the mobile version of the third top-level image."
        },
        {
          "type": "text",
          "id": "title_3",
          "label": "Title 3",
          "info": "Title for the third top-level link."
        },
        {
          "type": "text",
          "id": "icon_3",
          "label": "Icon 3",
          "info": "Icon for the third link."
        },
        {
          "type": "url",
          "id": "url_3",
          "label": "Link 3",
          "info": "URL for the third top-level link."
        },
        {
          "type": "text",
          "id": "button_text_3",
          "label": "Button Text 3",

        },
        {
          "type": "text",
          "id": "button_text_style_4",
          "label": "Button Style 4",
          "default": "b2",
          "info": "Style for the fourth top-level button."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "container_type",
      "label": "Container type",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "Use container width"
        },
        {
          "value": "w-full",
          "label": "Use full width"
        }
      ]
    },
    {
      "type": "text",
      "id": "custom_column_class",
      "label": "Custom Class",
      "info": "Custom Class"
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Color scheme",
      "info": "Select a color scheme for the megamenu."
    },
    {
      "type": "header",
      "content": "Megamenu Text Settings"
    },
    {
      "type": "text",
      "id": "title_style",
      "label": "Title Style",
      "info": "Style of the titles above links",
      "default": "b1"
    },
    {
      "type": "text",
      "id": "link_style",
      "label": "Link Style",
      "info": "Style of the links displayed",
      "default": "b2"
    },
    {
      "type": "range",
      "id": "gap_between_text_y",
      "min": 1,
      "max": 50,
      "step": 1,
      "label": "Gap between links and titles (Vertical)",
      "default": 2,
      "info": "Gap between links and titles in pixels."
    },
    {
      "type": "header",
      "content": "Megamenu Options"
    },
    {
      "type": "select",
      "id": "container_type_inner",
      "label": "Container type (Inner)",
      "default": "container",
      "info": "Use this if you want the content inside the megamenu to be full width or not.",
      "options": [
        {
          "value": "container",
          "label": "Use container width"
        },
        {
          "value": "w-full",
          "label": "Use full width"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondlevel_open_always",
      "label": "Show 2nd Level Menu Open At All Times",
      "info": "This will apply if you want to show 2nd level menus open all the time, without a hover effect.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_thirdlevel_open_always",
      "label": "Show 3rd Level Menu Open At All Times",
      "info": "This will apply if you want to show 3rd level menus open all the time, without a hover effect.",
      "default": false
    },
    {
      "type": "select",
      "id": "column_spacing",
      "label": "Column Spacing",
      "options": [
        {
          "value": "none",
          "label": "Manual"
        },
        {
          "value": "justify-between",
          "label": "Even Spacing"
        },
        {
          "value": "justify-center",
          "label": "Centered"
        }
      ],
      "default": "justify-between",
      "info": "Use this if you want even spacing between the columns, this should be used primarily on the Default layout"
    },
    {
      "type": "number",
      "id": "column_width",
      "label": "Column Width",
      "info": "Set this if above is none, this will be the width of the columns in percentage, leave as 0 for auto"
    },
    {
      "type": "range",
      "id": "column_gap_x",
      "min": 1,
      "max": 50,
      "step": 1,
      "label": "Gap between columns (Horizontal)",
      "default": 8,
      "info": "Gap between columns in pixels."
    },
    {
      "type": "range",
      "id": "column_gap_y",
      "min": 1,
      "max": 50,
      "step": 1,
      "label": "Gap between columns (Vertical)",
      "default": 8,
      "info": "Gap between columns in pixels."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "info": "Select the main menu for the megamenu."
    },
    {
      "type": "select",
      "id": "megamenu_trigger",
      "options": [
        {
          "value": "onclick",
          "label": "On Click"
        },
        {
          "value": "onhover",
          "label": "On Hover"
        }
      ],
      "default": "onclick",
      "label": "Megamenu Trigger",
      "info": "Choose how the megamenu is triggered: by clicking or hovering."
    },
    {
      "type": "text",
      "id": "attach_to",
      "label": "Parent menu item",
      "info": "Specify a unique menu item from the parent menu to attach the megamenu."
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "sidebar",
          "label": "Sidebar"
        }
      ],
      "default": "default",
      "label": "Layout",
      "info": "Choose the layout style for the megamenu on desktop devices."
    },
    {
      "type": "select",
      "id": "layout_mobile",
      "options": [
        {
          "value": "drilldown",
          "label": "Drill Down"
        },
        {
          "value": "Accordion",
          "label": "Accordion"
        }
      ],
      "default": "drilldown",
      "label": "Layout (Mobile)",
      "info": "Choose the layout style for the megamenu on mobile devices"
    },
    {
      "type": "header",
      "content": "Featured Image Settings"
    },
    {
      "type": "select",
      "id": "image_layout",
      "options": [
        {
          "value": "stacked",
          "label": "Stacked"
        },
        {
          "value": "grid",
          "label": "Grid"
        }
      ],
      "default": "grid",
      "label": "Image Layout",
      "info": "Choose the layout for featured images."
    },
    {
      "type": "range",
      "id": "featured_column_gap_x",
      "min": 1,
      "max": 50,
      "step": 1,
      "label": "Gap between columns (Horizontal)",
      "default": 8,
      "info": "Gap between columns in pixels."
    },
    {
      "type": "range",
      "id": "featured_column_gap_y",
      "min": 1,
      "max": 50,
      "step": 1,
      "label": "Gap between columns (Vertical)",
      "default": 8,
      "info": "Gap between columns in pixels."
    },
    {
      "type": "range",
      "id": "col_count",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Column Count (Grid)",
      "default": 4,
      "info": "Set the number of columns in the grid layout."
    },
    {
      "type": "header",
      "content": "Padding & Alignment settings"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Mobile",
      "default": 0
    },
    {
      "type": "select",
      "id": "content_alignment_desktop",
      "options": [
        {
          "value": "start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "end",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Content Alignment Desktop"
    },
    {
      "type": "select",
      "id": "content_alignment_mobile",
      "options": [
        {
          "value": "start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "end",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Content Alignment Mobile"
    },
    {
      "type": "select",
      "id": "content_position_desktop",
      "options": [
        {
          "value": "start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "end",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Content Position Desktop"
    }
  ],
  "presets": [
    {
      "name": "Megamenu"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}

        },
        {
          "type": "text",
          "id": "button_text_style_3",
          "label": "Button Style 3",
          "default": "b2",
          "info": "Style for the third top-level button."
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Image 4",
          "info": "Select the fourth top-level image."
        },
        {
          "type": "image_picker",
          "id": "mobile_image_4",
          "label": "Image 4 (Mobile)",
          "info": "Select the mobile version of the fourth top-level image."
        },
        {
          "type": "text",
          "id": "title_4",
          "label": "Title 4",
          "info": "Title for the fourth top-level link."
        },
        {
          "type": "text",
          "id": "icon_4",
          "label": "Icon 4",
          "info": "Icon for the fourth link."
        },
        {
          "type": "url",
          "id": "url_4",
          "label": "Link 4",
          "info": "URL for the fourth top-level link."
        },
        {
          "type": "text",
          "id": "button_text_4",
          "label": "Button Text 4",

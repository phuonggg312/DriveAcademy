<div class="section-megamenu section-megamenu-{{ section.id }} {{ section.settings.custom_column_class }} flex flex-col w-full {{ settings.reveal_animation_class }} color-{{ section.settings.color_schema }}">
  <div class="react-node">
    {% include 'react-props' %}
    <div id="react-data" data-injected-props='{{ data }}'></div>
    {% render 'react-block', name: "theme__navigation-megamenu", props: data %}
  </div>
</div>

{% schema %}
{
  "name": "Megamenu",
  "tag": "section",
  "class": "section megamenu-sticky",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "overlay",
      "name": "Overlay",
      "settings": [
        {
          "type": "header",
          "content": "Overlay Settings",
          "info": "Configure this if you want to adjust the page overlay that happens behind the Megamenu"
        },
        {
          "type": "select",
          "id": "mask",
          "label": "Overlay",
          "default": "none",
            "options": [
                {
                  "value": "none",
                  "label": "None"
                },
                {
                  "value": "blur",
                  "label": "Blur"
                },
                {
                  "value": "darken",
                  "label": "Darken"
                }
            ],
          "info": "Select the overlay style for the megamenu."
        },
        {
          "type": "number",
          "id": "effect_size",
          "label": "Effect Size",
          "info": "This will be the value of the effect applied, blur will be in pixels, darken will be in percentage"
        }
      ]
    },
    {
      "type": "images",
      "name": "Images",
      "settings": [
        {
          "type": "header",
          "content": "Featured Blocks Settings",
          "info": "Configure the featured blocks that will be displayed in the megamenu."
        },
        {
          "type": "select",
          "id": "button_layout",
          "label": "Button Layout",
          "options": [
            {
              "value": "megamenu__cta-item-underneath",
              "label": "Under"
            },
            {
              "value": "megamenu__cta-item-overlay",
              "label": "Overlay"
            }
          ],
          "info": "Select the layout for buttons in the CTA block."
        },
        {
          "type": "number",
          "id": "column",
          "label": "Column",
          "default": 2,
          "info": "Column this will be rendered in"
        },
        {
          "type": "number",
          "id": "width",
          "label": "Column Width",
          "default": 0,
          "info": "In percentage how much space you want this block to take"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Linked Submenu",
          "info": "Title for the linked submenu section."
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1",
          "info": "Select the first image for the submenu."
        },
        {
          "type": "image_picker",
          "id": "mobile_image_1",
          "label": "Image 1 (Mobile)",
          "info": "Select the mobile version of the first image."
        },
        {
          "type": "text",
          "id": "title_1",
          "label": "Title 1",
          "info": "Title for the first link."
        },
        {
          "type": "text",
          "id": "icon_1",
          "label": "Icon 1",
          "info": "Icon for the first link."
        },
        {
          "type": "url",
          "id": "url_1",
          "label": "Link 1",
          "info": "URL for the first link."
        },
        {
          "type": "text",
          "id": "button_text_1",
          "label": "Button Text 1",
          "info": "Text for the first button."
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2",
          "info": "Select the second image for the submenu."
        },
        {
          "type": "image_picker",
          "id": "mobile_image_2",
          "label": "Image 2 (Mobile)",
          "info": "Select the mobile version of the second image."
        },
        {
          "type": "text",
          "id": "title_2",
          "label": "Title 2",
          "info": "Title for the second link."
        },
        {
          "type": "text",
          "id": "icon_2",
          "label": "Icon 2",
          "info": "Icon for the second link."
        },
        {
          "type": "url",
          "id": "url_2",
          "label": "Link 2",
          "info": "URL for the second link."
        },
        {
          "type": "text",
          "id": "button_text_2",
          "label": "Button Text 2",
          "info": "Text for the second button."
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3",
          "info": "Select the third image for the submenu."
        },
        {
          "type": "image_picker",
          "id": "mobile_image_3",
          "label": "Image 3 (Mobile)",
          "info": "Select the mobile version of the third image."
        },
        {
          "type": "text",
          "id": "title_3",
          "label": "Title 3",
          "info": "Title for the third link."
        },
        {
          "type": "text",
          "id": "icon_3",
          "label": "Icon 3",
          "info": "Icon for the third link."
        },
        {
          "type": "url",
          "id": "url_3",
          "label": "Link 3",
          "info": "URL for the third link."
        },
        {
          "type": "text",
          "id": "button_text_3",
          "label": "Button Text 3",
          "info": "Text for the third button."
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Image 4",
          "info": "Select the fourth image for the submenu."
        },
        {
          "type": "image_picker",
          "id": "mobile_image_4",
          "label": "Image 4 (Mobile)",
          "info": "Select the mobile version of the fourth image."
        },
        {
          "type": "text",
          "id": "title_4",
          "label": "Title 4",
          "info": "Title for the fourth link."
        },
        {
          "type": "text",
          "id": "icon_4",
          "label": "Icon 4",
          "info": "Icon for the fourth link."
        },
        {
          "type": "url",
          "id": "url_4",
          "label": "Link 4",
          "info": "URL for the fourth link."
        },
        {
          "type": "text",
          "id": "button_text_4",
          "label": "Button Text 4",
          "info": "Text for the fourth button."
        }
      ]
    },
    {
      "type": "toparea",
      "name": "Top Level",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Top Level Featured Blocks Settings",

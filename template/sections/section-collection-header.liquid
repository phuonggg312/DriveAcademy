            "value": "image",
            "label": "Header with Image"
          },
          {
            "value": "no_image",
            "label": "Header without Image"
          },
          {
            "value": "headercollections",
            "label": "Header & Collections"
          }
        ]
      },
      {
        "type": "select",
        "id": "layout_type_mobile",
        "label": "Layout (Mobile)",
        "default": "image",
        "options": [
          {
            "value": "image",
            "label": "Header with Image"
          },
          {
            "value": "no_image",

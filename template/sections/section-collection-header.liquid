{%- liquid
  if section.settings.mobile_image
    assign mobile_image = section.settings.mobile_image
  else
    assign mobile_image = section.settings.image
  endif
-%}

<div class="color-{{ section.settings.color_schema }}">
  <div
    class="section-collection-header-{{ section.id }} {{ settings.reveal_animation_class }}"
      x-data="section({{ section.settings | json | escape }})"
      :class="classes"
  >
    <div class="{{ section.settings.container_type }}">
      <div class="react-node w-full">

      {% assign metaobject_name = "collections.featured_collections" %}
      {% assign metaobject_parts = metaobject_name | split: '.' %}
      {% assign namespace = metaobject_parts[0] %}
      {% assign key = metaobject_parts[1] %}

      {% assign featured_collections_metafield = collection.metafields[namespace][key] %}
      {% assign featured_collections = featured_collections_metafield.value %}

        {% capture data %}
          {
            "section": {{ section.settings | json }},
            "description": "{{ collection.description }}",
            "mobile_image": "{{ mobile_image | image_url }}",
            "featured_collections": [
              {% for collection in featured_collections %}
                  {% assign collection_object = collections[collection.handle] %}

                      {% if collection_object %}
                      {
                          "id": "{{ collection_object.id }}",
                          "title": "{{ collection_object.title | escape }}",
                          "image": "{{ collection_object.image | image_url: width: collection_object.image.width }}",
                          "link": "{{ collection_object.url }}"
                      }{% if forloop.last == false %},{% endif %}
                      {% endif %}

              {% endfor %}
            ]
          }
        {% endcapture %}
        {% assign data = data | escape %}

        <div id="react-data" data-injected-props='{{ data }}'></div>
        {% render 'react-block', name: "theme__collection-header", props: data %}
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Collection Header",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "select",
        "id": "layout_type",
        "label": "Layout",
        "default": "image",
        "options": [

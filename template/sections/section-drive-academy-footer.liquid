{% capture custom_data %}
{
  "section": {
    "logo_text": "{{ section.settings.logo_text | escape }}",
    "description": "{{ section.settings.description | escape }}",
    "facebook_url": "{{ section.settings.facebook_url | escape }}",
    "twitter_url": "{{ section.settings.twitter_url | escape }}",
    "instagram_url": "{{ section.settings.instagram_url | escape }}",
    "linkedin_url": "{{ section.settings.linkedin_url | escape }}",
    "quick_links_title": "{{ section.settings.quick_links_title | escape }}",
    "courses_title": "{{ section.settings.courses_title | escape }}",
    "newsletter_heading": "{{ section.settings.newsletter_heading | escape }}",
    "newsletter_description": "{{ section.settings.newsletter_description | escape }}",
    "newsletter_placeholder": "{{ section.settings.newsletter_placeholder | escape }}",
    "copyright": "{{ section.settings.copyright | escape }}"
  },
  "quick_links": [
    {% if section.settings.quick_links != blank %}
    {% for link in linklists[section.settings.quick_links].links %}
    { "title": "{{ link.title | escape }}", "url": "{{ link.url | escape }}" }{% unless forloop.last %},{% endunless %}
    {% endfor %}
    {% endif %}
  ],
  "courses": [
    {% if section.settings.courses_menu != blank %}
    {% for link in linklists[section.settings.courses_menu].links %}
    { "title": "{{ link.title | escape }}", "url": "{{ link.url | escape }}" }{% unless forloop.last %},{% endunless %}
    {% endfor %}
    {% endif %}
  ]
}
{% endcapture %}
{% assign data = custom_data | strip_newlines | replace: "'", "&#39;" %}
<div
  class="section-drive-academy-footer color-{{ section.settings.color_schema }} w-full {{ settings.reveal_animation_class }}"
  id="section-{{ section.id }}"
  x-data="section({{ section.settings | json | escape }})"
  :class="classes"
>
  <div class="{{ section.settings.container_type }}">
    <div id="react-data" data-injected-props='{{ data }}'></div>
    {% render 'react-block', name: "theme__drive-academy-footer", props: data %}
  </div>
</div>

{% schema %}
{
  "name": "Drive Academy Footer",
  "tag": "footer",
  "class": "footer",
  "settings": [
    {
      "type": "header",
      "content": "Column 1 - Logo & Social"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo / Brand name",
      "default": "Autoguru"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Our certified programs are designed to provide structured, professional training that builds safe and confident drivers."
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "X (Twitter) URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "linkedin_url",
      "label": "LinkedIn URL"
    },
    {
      "type": "header",
      "content": "Column 2 - Quick Links"
    },
    {
      "type": "text",
      "id": "quick_links_title",
      "label": "Quick Links heading",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "quick_links",
      "label": "Quick Links menu"
    },
    {
      "type": "header",
      "content": "Column 3 - Our Courses"
    },
    {
      "type": "text",
      "id": "courses_title",
      "label": "Courses heading",
      "default": "Our Courses"
    },
    {
      "type": "link_list",
      "id": "courses_menu",
      "label": "Courses menu"
    },
    {
      "type": "header",
      "content": "Column 4 - Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Subscribe To Newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_description",
      "label": "Newsletter description",
      "default": "Our certified programs are designed to provide structure, professional training that builds both driving skills and confidence."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "Enter Email Address*"
    },
    {
      "type": "header",
      "content": "Bottom"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "Copyright © 2026 All Rights Reserved."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container type",
      "default": "container",
      "options": [
        { "value": "container", "label": "Use container width" },
        { "value": "w-full", "label": "Use full width" }
      ]
    },
    {
      "type": "header",
      "content": "Padding & Alignment settings"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_left_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Mobile",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Drive Academy Footer"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}


<div
  class="color-{{ section.settings.color_schema }}
    account-dashboard"
  x-data="section({{ section.settings | json | escape }})"
  :class="classes"
>
    <div class="account">
      {% render 'account-topbar' %}
      <div class="account-wrapper">
        <div class="account-container">
          {% if section.settings.layout_type == 'default' %}
          <div class="account__{{ section.settings.layout_type}}">
            {% elsif section.settings.layout_type == 'stacked' %}
            <div class="account__{{ section.settings.layout_type }}">
              {% endif %}
              {% render 'account-sidebar' %}

              <div class="account-details">
                {% render 'account-header', title: "My Offers and Codes", subtext: "My Account" %}

                <div class="max-w-[calc(1440px-320px)]">
                  {% render 'account-discounts', blocks: section.blocks %}
                </div>
              </div>
            </div>

            {% render 'account-links' %}

          </div>
        </div>
      </div>
    </div>

{% schema %}
{
  "name": "Account Discounts",
  "tag": "header",
  "blocks": [
  {
    "type": "discount_block",
    "name": "Discount Block",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color",
            "label": "Color Schema",
            "default": "Color Schema"
        },
        {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "10% off for new email subscribers"
        },
        {
            "type": "text",
            "id": "expiry_date",
            "label": "Expiry",
            "default": "12/6/2024",
            "info": "Enter the expiry date of the code. (Format: DD/MM/YYYY)"
        },
        {
            "type": "text",
            "id": "code_text",
            "label": "Code Explanation",
            "default": "Apply this code during checkout to get 10% off your order."
        },
        {
            "type": "text",
            "id": "code",
            "label": "Code",
            "default": "NEW!2345",
            "info": "Enter the code that the customer will use to get the discount. (Will check tag <code>:true and remove if found on customer)"
        },
        {
            "type": "checkbox",
            "id": "is_code_multiple_use",
            "label": "Code is for multiple use",
            "default": false,
            "info": "Check this box if the code can be used multiple times."
        },
        {
            "type": "text",
            "id": "customer_unique_tags",
            "label": "Unique tags for customer to check",
            "info": "Enter the unique tag that the customer will use to check if the code is valid. (Comma seperated)"
        },
        {
            "type": "richtext",
            "id": "code_terms",
            "label": "Code Terms",
            "default": "<p>Read the Terms And Conditions of this offer.</p>"
        }
    ]
  }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Render settings"
    },
    {
      "type": "select",
      "id": "layout_type",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "stacked",
          "label": "Stacked"
        }
      ],
      "default": "default",
      "label": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Padding Settings"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left_right_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Left & Right Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left_right_mobile",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Left & Right Mobile",
      "default": 0
    }
  ]
}
{% endschema %}

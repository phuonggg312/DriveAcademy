<div
  class="section-about-features color-{{ section.settings.color_schema }} {{ section.settings.container_type }} {{ settings.reveal_animation_class }}"
  id="section-{{ section.id }}"
  x-data="section({{ section.settings | json | escape }})"
  :class="classes"
>
  <div class="max-w-5xl mx-auto">
    {% if section.settings.tagline != blank %}
      <p class="text-xs md:text-sm font-semibold uppercase tracking-wider text-[#B45309] mb-2">
        {{ section.settings.tagline }}
      </p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <p class="text-2xl md:text-3xl lg:text-4xl font-bold text-inherit mb-4 pb-4 border-b border-[#F0D32A]/40">
        {{ section.settings.heading }}
      </p>
    {% endif %}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10 mt-8">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <div class="flex flex-col" {{ block.shopify_attributes }}>
            <div class="w-14 h-14 rounded-full border-2 border-[#F0D32A] bg-[#FEF3C7] flex items-center justify-center flex-shrink-0 mb-4 overflow-hidden">
              {% if block.settings.icon != blank %}
                <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="" class="w-7 h-7 object-contain" />
              {% else %}
                <span class="text-lg font-bold text-[#B45309]">{{ block.settings.number | default: '01' }}</span>
              {% endif %}
            </div>
            <p class="text-lg md:text-xl font-bold text-inherit mb-2">
              <span class="text-[#B45309]">{{ block.settings.number | default: '01' }}</span>
              {{ block.settings.title }}
            </p>
            {% if block.settings.description != blank %}
              <p class="text-sm opacity-90 leading-relaxed">{{ block.settings.description }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Features",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "OUR FEATURES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Who Should Get Driving Lessons?"
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container",
      "default": "container",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "w-full", "label": "Full width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_left_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_left_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Mobile",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Optional. If empty, number is shown in circle."
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Choosing A Driving School"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "The right driving school is accredited according to state laws and will prepare you to be a safe, confident driver."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Features",
      "category": "About",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "number": "01",
            "title": "Choosing A Driving School",
            "description": "The right driving school is accredited according to state laws and will prepare you to be a safe, confident driver."
          }
        },
        {
          "type": "feature",
          "settings": {
            "number": "02",
            "title": "Driving Basics",
            "description": "When you first start learning to drive, it can seem a little overwhelming. We know that, but don't worry."
          }
        },
        {
          "type": "feature",
          "settings": {
            "number": "03",
            "title": "Road Test Preparation",
            "description": "Practice makes perfect! We know you've heard that before, but it's especially true with driving."
          }
        }
      ]
    }
  ]
}
{% endschema %}

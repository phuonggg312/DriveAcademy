{% assign blog = section.settings.blog %}
{% assign articles_to_show = section.settings.articles_to_show | default: 3 %}

{% capture custom_data %}
{
  "section": {
    "tagline": "{{ section.settings.tagline | escape }}",
    "heading": "{{ section.settings.heading | escape }}",
    "read_more_text": "{{ section.settings.read_more_text | escape }}",
    "view_all_text": "{{ section.settings.view_all_text | escape }}",
    "bottom_text": "{{ section.settings.bottom_text | escape }}",
    "view_all_url": {% if blog %}"{{ blog.url | escape }}"{% else %}""{% endif %},
    "padding_top_desktop": {{ section.settings.padding_top_desktop | default: 24 }},
    "padding_bottom_desktop": {{ section.settings.padding_bottom_desktop | default: 24 }},
    "padding_left_right_desktop": {{ section.settings.padding_left_right_desktop | default: 24 }},
    "padding_top_mobile": {{ section.settings.padding_top_mobile | default: 16 }},
    "padding_bottom_mobile": {{ section.settings.padding_bottom_mobile | default: 16 }},
    "padding_left_right_mobile": {{ section.settings.padding_left_right_mobile | default: 16 }}
  },
  "articles": [
    {% if blog and blog.articles.size > 0 %}
      {% for article in blog.articles limit: articles_to_show %}
        {
          "title": "{{ article.title | escape }}",
          "url": "{{ article.url | escape }}",
          "image": {% if article.image %}"{{ article.image | image_url: width: 800 | escape }}"{% else %}null{% endif %},
          "published_at": "{{ article.published_at | date: '%d %b, %y' | escape }}",
          "author": "{{ article.author | escape }}",
          "category": {% if article.tags.size > 0 %}"{{ article.tags[0] | escape }}"{% else %}"{{ blog.title | escape }}"{% endif %}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    {% endif %}
  ]
}
{% endcapture %}
{% assign data = custom_data | strip_newlines | replace: "'", "&#39;" %}
<div
  class="section-drive-academy-blog color-{{ section.settings.color_schema }} w-full {{ settings.reveal_animation_class }}"
  id="section-{{ section.id }}"
  x-data="section({{ section.settings | json | escape }})"
  :class="classes"
>
  <div class="{{ section.settings.container_type }}">
    <div id="react-data" data-injected-props='{{ data }}'></div>
    {% render 'react-block', name: "theme__drive-academy-blog", props: data %}
  </div>
</div>

{% schema %}
{
  "name": "Latest from Our Blog",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "BLOG POST"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Latest from Our Blog"
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read more text",
      "default": "READ MORE"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all text",
      "default": "VIEW ALL"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom line text",
      "default": "Don't stop here, More blog posts ahead."
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Number of articles",
      "default": 3
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container type",
      "default": "container",
      "options": [
        { "value": "container", "label": "Use container width" },
        { "value": "w-full", "label": "Use full width" }
      ]
    },
    {
      "type": "header",
      "content": "Padding & Alignment"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_left_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_left_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Mobile",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Latest from Our Blog",
      "category": "Drive Academy"
    }
  ]
}
{% endschema %}

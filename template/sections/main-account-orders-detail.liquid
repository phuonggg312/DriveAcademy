<div class="color-{{ section.settings.color_schema }}
account-dashboard"
     x-data="section({{ section.settings | json | escape }})"
     :class="classes"
>
    <div class="account">
        {% render 'account-topbar' %}
        <div class="account-wrapper">
            <div class="account-container">
                {% if section.settings.layout_type == 'default' %}
                <div class="account__{{ section.settings.layout_type}}">
                    {% elsif section.settings.layout_type == 'stacked' %}
                    <div class="account__{{ section.settings.layout_type }}">
                        {% endif %}
                        {% render 'account-sidebar' %}

                        <div class="account-details">
                            <div class="account-header">
                                <div class="account-header-container max-w-[calc(1440px-320px)]">
                                    <p class="text-sm font-normal lg:hidden mb-3">
                                        <a
                                            href="/account?view=orders"
                                            class="flex items center gap-2 no-underline hover:no-underline"
                                        >
                                            <i class="icon icon-caret-left-thin text-lg"></i>
                                            <span class="hover:underline">Order History</span>
                                        </a>
                                    </p>

                                    <div class="flex justify-between">
                                        <div class="account-header__info lg:space-y-[32px] space-y-[24px]">
                                            <div>
                                                <p class="text-sm font-normal hidden lg:flex mb-3">
                                                    <a
                                                        href="/account?view=orders"
                                                        class="flex items center gap-2 no-underline hover:no-underline"
                                                    >
                                                        <i class="icon icon-caret-left-thin text-lg"></i>
                                                        <span class="hover:underline">Order History</span>
                                                    </a>
                                                </p>

                                                <h2 class="account-header__title hidden lg:block">Order {{ order.name }}</h2>
                                                <p class="account-header__title font-normal lg:hidden">Order {{ order.name }}</p>
                                            </div>
                                        </div>

                                        <div x-data="rebuy" class="account-actions items-end gap-x-[8px] lg:flex">
                                            {% assign order_products = "" %}
                                            {% if customer %}
                                                {% assign order_products = order.line_items %}
                                            {% endif %}
                                            {% capture order_products_json %}
                                                [
                                                {% for line_item in order.line_items %}
                                                    {
                                                    "quantity": {{ line_item.quantity }},
                                                    {% if line_item.variant_id %}"id": {{ line_item.variant_id }}{% endif %}
                                                    }{% unless forloop.last %},{% endunless %}
                                                {% endfor %}
                                                ]
                                            {% endcapture %}
                                            {% assign order_products_available = true %}

                                            {% for line_item in order.line_items %}

                                                {% if line_item.variant_id == blank %}
                                                    {% assign order_products_available = false %}
                                                {% endif %}

                                                {% assign product = all_products[line_item.product.handle] %}

                                                {% if product %}
                                                    {% if product.available %}
                                                    {% else %}
                                                        {% assign order_products_available = false %}
                                                    {% endif %}
                                                {% else %}
                                                    {% assign order_products_available = false %}
                                                {% endif %}
                                            {% endfor %}


                                            {% comment %} <button id="reorder-button"
                                                    {% if order_products_available %}
                                                        class="orders__action orders__action--buy-again button button-tertiary flex-1"
                                                        x-on:click=" const products = {{ order_products_json |   escape  | replace: "'", "&#39;" }};
                                        rebuyOrder(products);"
                                                    {% else %}
                                                        class="orders__action orders__action--buy-again button button-tertiary flex-1 "
                                                        disabled
                                                    {% endif %}
                                            >
                                                Buy Again
                                            </button> {% endcomment %}
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="max-w-[calc(1440px-320px)]">
                                {% render 'account-tabbed-navigation' %}
                                {% render 'account-order-details' %}
                            </div>
                        </div>
                    </div>
                    {% render 'account-links' %}

                </div>
            </div>
        </div>
    </div>


    {% schema %}
    {
    "name": "Account Orders Detail",
    "tag": "header",
    "settings": [
    {
    "type": "header",
    "content": "Render settings"
    },
    {
    "type": "select",
    "id": "layout_type",
    "options": [
    {
    "value": "default",
    "label": "Default"
    },
    {
    "value": "stacked",
    "label": "Stacked"
    }
    ],
    "default": "default",
    "label": "Layout"
    },
    {
    "type": "color_scheme",
    "id": "color_schema",
    "label": "Color scheme"
    },
    {
    "type": "header",
    "content": "Padding Settings"
    },
    {
    "type": "range",
    "id": "padding_top_desktop",
    "min": 0,
    "max": 200,
    "step": 2,
    "unit": "px",
    "label": "Padding Top Desktop",
    "default": 0
    },
    {
    "type": "range",
    "id": "padding_bottom_desktop",
    "min": 0,
    "max": 200,
    "step": 2,
    "unit": "px",
    "label": "Padding Bottom Desktop",
    "default": 0
    },
    {
    "type": "range",
    "id": "padding_left_right_desktop",
    "min": 0,
    "max": 200,
    "step": 2,
    "unit": "px",
    "label": "Padding Left & Right Desktop",
    "default": 0
    },
    {
    "type": "range",
    "id": "padding_top_mobile",
    "min": 0,
    "max": 200,
    "step": 2,
    "unit": "px",
    "label": "Padding Top Mobile",
    "default": 0
    },
    {
    "type": "range",
    "id": "padding_bottom_mobile",
    "min": 0,
    "max": 200,
    "step": 2,
    "unit": "px",
    "label": "Padding Bottom Mobile",
    "default": 0
    },
    {
    "type": "range",
    "id": "padding_left_right_mobile",
    "min": 0,
    "max": 200,
    "step": 2,
    "unit": "px",
    "label": "Padding Left & Right Mobile",
    "default": 0
    }
    ]
    }
{% endschema %}

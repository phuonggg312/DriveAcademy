{% assign metaobject_values = null %}

{% if section.settings.faq_metaobject_type == 'product' %}
  {% assign metafield_notations = section.settings.metaobject_entries | split: "." %}
  {% assign count = 0 %}
  {% for notation in metafield_notations %}
    {% if count == 0 %}
      {% assign metaobject_values = product.metafields[notation] %}
    {% else %}
      {% assign metaobject_values = metaobject_values[notation] %}
    {% endif %}
    {% assign count = count | plus: 1 %}
  {% endfor %}
  {% assign metaobject_values = metaobject_values.value %}
{% elsif section.settings.faq_metaobject_type == 'page' and page %}
  {% assign metafield_notations = section.settings.metaobject_entries | split: "." %}
  {% assign count = 0 %}
  {% for notation in metafield_notations %}
    {% if count == 0 %}
      {% assign metaobject_values = page.metafields[notation] %}
    {% else %}
      {% assign metaobject_values = metaobject_values[notation] %}
    {% endif %}
    {% assign count = count | plus: 1 %}
  {% endfor %}
  {% assign metaobject_values = metaobject_values.value %}
{% elsif section.settings.faq_metaobject_type == 'article' and article %}
  {% assign metafield_notations = section.settings.metaobject_entries | split: "." %}
  {% assign count = 0 %}
  {% for notation in metafield_notations %}
    {% if count == 0 %}
      {% assign metaobject_values = article.metafields[notation] %}
    {% else %}
      {% assign metaobject_values = metaobject_values[notation] %}
    {% endif %}
    {% assign count = count | plus: 1 %}
  {% endfor %}
  {% assign metaobject_values = metaobject_values.value %}
{% elsif section.settings.faq_metaobject_type == 'global' and section.settings.metaobject_entries != blank %}
  {% assign metaobject_values = shop.metaobjects[section.settings.metaobject_entries].values %}
{% endif %}

{% if section.settings.metaobject_entries != blank and section.settings.faq_metaobject_type != 'manual' %}
  {% assign faqs = metaobject_values %}
{% endif %}

{% capture faqData %}
  "faqs": {% if section.settings.faq_metaobject_type == 'manual' %} [
  {% assign first_manual = true %}
  {% for block in section.blocks %}
    {% if block.type == 'faq_item' %}
      {% unless first_manual %},{% endunless %}
      {% assign first_manual = false %}
      {"title": {{ block.settings.question | default: "" | json }}, "content": {{ block.settings.answer | default: "" | json }}}
    {% elsif block.type == 'column_block' %}
      {% unless first_manual %},{% endunless %}
      {% assign first_manual = false %}
      {"title": {{ block.settings.title | default: "" | json }},{% if block.settings.image %}"image": "{{ block.settings.image | image_url: width: 600 }}",{% endif %}"content": {{ block.settings.content | default: "" | json }}}
    {% endif %}
  {% endfor %}
  ]{% elsif faqs %} [
  {% for faq in faqs %}
    {
    "title": "{{ faq.question | escape }}",
    {% if faq.image %}"image": "{{ faq.image | image_url: width: 600 }}",{% endif %}
    "content": "{{ faq.answer | escape }}",
    "filter_tag": "{{ faq.dropdown_label | escape }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  ]{% else %}[]{% endif %}
{% endcapture %}

<div class="{{ section.settings.custom_column_class }} color-{{ section.settings.color_schema }}">
<div class="section-faq section-faq-{{ section.id }} color-{{ section.settings.color_schema }} relative {{ settings.reveal_animation_class }}"
     :class="classes"
     x-data="section({{ section.settings | json | escape }})"
>
    <div class="flex flex-col w-full lg:max-w-[{{ section.settings.content_width }}] {{ section.settings.container_type }} relative">
      <div class="react-node w-full">
        {% include 'react-props', metaobjectEntries: faqData %}
        <div id="react-data" data-injected-props='{{ data }}'></div>
        {% render 'react-block', name: "theme__faq", props: data %}
      </div>
    </div>
  </div>
</div>


        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    },
    {
      "type": "column_block",
      "name": "FAQ Block",
      "settings": [
        {
          "type": "number",
          "id": "column",
          "label": "Column",
          "default": 2
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "filter_tag",
          "label": "Filter Tag"
        },
        {
          "type": "header",
          "content": "Details"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "If video setting is blank, then image will display as media"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        }
      ]
    },
    {
      "type": "column_CTA",
      "name": "Column CTA",
      "settings": [
        {
          "type": "number",
          "id": "column",
          "label": "Column",

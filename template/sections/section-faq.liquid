        },
        {
          "type": "text",
          "id": "cta_style",
          "label": "CTA Style",
          "default": "button-primary"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTA URL"
        },

      ]
    },
    {
      "type": "column_image",
      "name": "FAQ Image",
      "settings": [
        {
          "type": "number",
          "id": "column",
          "label": "Column",
          "default": 2
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "If video setting is blank, then image will display as media"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        }
      ]
    }
  ],
  "settings": [
  {
    "type": "select",
    "id": "render_type",
    "options": [
      {
        "value": "all",
        "label": "All"
      },
      {
        "value": "mobile-only",
        "label": "Mobile Only"
      },
      {
        "value": "desktop-only",
        "label": "Desktop Only"
      }
    ],
    "default": "all",
    "label": "Render Type",
    "info": "This will display this block based on Desktop, Mobile or both."

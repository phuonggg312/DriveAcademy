{%- if section.settings.image -%}
  {%- assign image_url = section.settings.image | image_url: width: 800 -%}
{%- else -%}
  {%- assign image_url = '' -%}
{%- endif -%}

{% capture custom_data %}
{
  "section": {
    "tagline": "{{ section.settings.tagline | escape }}",
    "heading": "{{ section.settings.heading | escape }}",
    "description": "{{ section.settings.description | escape }}",
    "image_url": {% if section.settings.image %}"{{ image_url }}"{% else %}null{% endif %},
    "overlay_heading": "{{ section.settings.overlay_heading | escape }}",
    "overlay_bullet_1": "{{ section.settings.overlay_bullet_1 | escape }}",
    "overlay_bullet_2": "{{ section.settings.overlay_bullet_2 | escape }}"
  },
  "blocks": [
    {% for block in section.blocks %}
    {% if block.settings.icon_image %}
      {% assign wcu_icon_url = block.settings.icon_image | image_url: width: 96 %}
    {% else %}
      {% assign wcu_icon_url = '' %}
    {% endif %}
    {
      "id": "{{ block.id }}",
      "type": "{{ block.type | escape }}",
      "settings": {
        "icon": "{{ block.settings.icon | escape }}",
        "icon_image_url": {% if block.settings.icon_image %}"{{ wcu_icon_url }}"{% else %}null{% endif %},
        "title": "{{ block.settings.title | escape }}",
        "description": "{{ block.settings.description | escape }}",
        "number": "{{ block.settings.number | escape }}"
      }
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
{% endcapture %}
{% assign data = custom_data | strip_newlines | replace: "'", "&#39;" %}
<div
  class="section-why-choose-us color-{{ section.settings.color_schema }} w-full {{ settings.reveal_animation_class }}"
  id="section-{{ section.id }}"
  x-data="section({{ section.settings | json | escape }})"
  :class="classes"
>
  <div class="{{ section.settings.container_type }}">
    <div id="react-data" data-injected-props='{{ data }}'></div>
    {% render 'react-block', name: "theme__why-choose-us", props: data %}
  </div>
</div>

{% schema %}
{
  "name": "Why Choose Us",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Left column"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Why Choose Us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why our driving school is trusted by learners"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We focus on delivering safe, skilled, and confident drivers through expert training, modern vehicles, and personalized learning methods. Our certified instructors provide patient, step-by-step guidance."
    },
    {
      "type": "header",
      "content": "Right column - Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Instructor/student in car. Recommended vertical orientation."
    },
    {
      "type": "header",
      "content": "Image overlay"
    },
    {
      "type": "text",
      "id": "overlay_heading",
      "label": "Overlay heading",
      "default": "Certified & Experienced Instructors"
    },
    {
      "type": "text",
      "id": "overlay_bullet_1",
      "label": "Overlay bullet 1",
      "default": "Certified and experienced driving instructor"
    },
    {
      "type": "text",
      "id": "overlay_bullet_2",
      "label": "Overlay bullet 2",
      "default": "Step-by-step, easy-to-follow training method"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container type",
      "default": "container",
      "options": [
        { "value": "container", "label": "Use container width" },
        { "value": "w-full", "label": "Use full width" }
      ]
    },
    {
      "type": "header",
      "content": "Padding & Alignment settings"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_left_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Mobile",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon (default)",
          "default": "target",
          "info": "Used when no custom image is set.",
          "options": [
            { "value": "target", "label": "Target / Bullseye" },
            { "value": "diamond", "label": "Diamond" },
            { "value": "building", "label": "Building" }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom icon image",
          "info": "Optional. If set, this image is used instead of the default icon above."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Advanced Driving Program"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Learn from skilled, patient, and certified trainers who guide you step-by-step with clear techniques and safe practices."
        }
      ]
    },
    {
      "type": "stat",
      "name": "Stat card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon (default)",
          "default": "target",
          "info": "Used when no custom image is set.",
          "options": [
            { "value": "target", "label": "Target" },
            { "value": "money", "label": "Money / Trust" },
            { "value": "globe", "label": "Globe" }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom icon image",
          "info": "Optional. If set, this image is used instead of the default icon above."
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "1.5k+"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Learners who mastered safe and confident driving with us."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "target",
            "title": "Advanced Driving Program",
            "description": "Learn from skilled, patient, and certified trainers who guide you step-by-step with clear techniques and safe practices."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "diamond",
            "title": "Personalized Learning Experience",
            "description": "Learn from skilled, patient, and certified trainers who guide you step-by-step with clear techniques and safe practices."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "building",
            "title": "High Driving Test Success Rate",
            "description": "Learn from skilled, patient, and certified trainers who guide you step-by-step with clear techniques and safe practices."
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "target",
            "number": "1.5k+",
            "description": "Learners who mastered safe and confident driving with us."
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "money",
            "number": "98%",
            "description": "Trusted by thousands for professional and effective training."
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "globe",
            "number": "100%",
            "description": "Committed to safe driving practices with well-maintained vehicles."
          }
        }
      ]
    }
  ]
}
{% endschema %}

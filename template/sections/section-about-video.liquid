{%- assign video_url = section.settings.video_url | strip -%}
{%- assign use_embed = false -%}
{%- if video_url != blank -%}
  {%- if video_url contains 'youtube.com' or video_url contains 'youtu.be' -%}
    {%- assign use_embed = true -%}
    {%- if video_url contains 'youtu.be/' -%}
      {%- assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first -%}
    {%- else -%}
      {%- assign video_id = video_url | split: 'v=' | last | split: '&' | first -%}
    {%- endif -%}
    {%- assign embed_src = 'https://www.youtube.com/embed/' | append: video_id -%}
  {%- elsif video_url contains 'vimeo.com' -%}
    {%- assign use_embed = true -%}
    {%- assign video_id = video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
    {%- assign embed_src = 'https://player.vimeo.com/video/' | append: video_id -%}
  {%- endif -%}
{%- endif -%}

<div
  class="section-about-video color-{{ section.settings.color_schema }} {{ section.settings.container_type }} {{ settings.reveal_animation_class }}"
  id="section-{{ section.id }}"
  x-data="section({{ section.settings | json | escape }})"
  :class="classes"
>
  <div class="max-w-4xl mx-auto">
    {% if section.settings.heading != blank %}
      <p class="text-xl md:text-2xl font-bold text-inherit mb-6 text-center">
        {{ section.settings.heading }}
      </p>
    {% endif %}
    <div class="relative rounded-xl overflow-hidden border-2 border-[#F0D32A]/50 bg-[rgb(var(--color-background-contrast))]" style="padding-bottom: 56.25%;">
      {% if use_embed and embed_src %}
        <iframe
          src="{{ embed_src }}"
          class="absolute inset-0 w-full h-full"
          title="{{ section.settings.heading | default: 'Video' }}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      {% elsif section.settings.video != blank %}
        {{ section.settings.video | video_tag: autoplay: false, loop: false, controls: true, class: 'absolute inset-0 w-full h-full object-cover' }}
      {% else %}
        <div class="absolute inset-0 flex items-center justify-center text-inherit opacity-60">
          <p class="text-sm">Add a video URL (YouTube/Vimeo) or upload a video in the section settings.</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Video",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See how we teach"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL",
      "info": "YouTube or Vimeo link. Takes priority over uploaded video."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "Used when no Video URL is set."
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container",
      "default": "container",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "w-full", "label": "Full width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_left_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_left_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Mobile",
      "default": 16
    }
  ],
  "presets": [
    { "name": "About Video", "category": "About" }
  ]
}
{% endschema %}

{%- if section.settings.background_image -%}
  {%- assign bg_url = section.settings.background_image | image_url: width: 1920 -%}
{%- else -%}
  {%- assign bg_url = '' -%}
{%- endif -%}

{% capture custom_data %}
{
  "background_image_url": {% if section.settings.background_image %}"{{ bg_url }}"{% else %}null{% endif %},
  "section": {
    "tagline": "{{ section.settings.tagline | escape }}",
    "heading": "{{ section.settings.heading | escape }}",
    "description": "{{ section.settings.description | escape }}",
    "contact_text": "{{ section.settings.contact_text | escape }}",
    "contact_url": "{{ section.settings.contact_url | escape }}",
    "video_url": "{{ section.settings.video_url | escape }}",
    "overlay_opacity": {{ section.settings.overlay_opacity | default: 60 }},
    "padding_top_mobile": {{ section.settings.padding_top_mobile | default: 16 }},
    "padding_bottom_mobile": {{ section.settings.padding_bottom_mobile | default: 16 }},
    "padding_left_right_mobile": {{ section.settings.padding_left_right_mobile | default: 16 }},
    "padding_top_desktop": {{ section.settings.padding_top_desktop | default: 24 }},
    "padding_bottom_desktop": {{ section.settings.padding_bottom_desktop | default: 24 }},
    "padding_left_right_desktop": {{ section.settings.padding_left_right_desktop | default: 24 }}
  },
  "section_id": "{{ section.id }}",
  "blocks": [
    {% for block in section.blocks %}
    {% if block.settings.icon_image %}
      {% assign wwd_icon_url = block.settings.icon_image | image_url: width: 96 %}
    {% else %}
      {% assign wwd_icon_url = '' %}
    {% endif %}
    {
      "id": "{{ block.id }}",
      "type": "{{ block.type | escape }}",
      "settings": {
        "title": "{{ block.settings.title | escape }}",
        "description": "{{ block.settings.description | escape }}",
        "icon": "{{ block.settings.icon | escape }}",
        "icon_image_url": {% if block.settings.icon_image %}"{{ wwd_icon_url }}"{% else %}null{% endif %}
      }
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
{% endcapture %}
{% assign data = custom_data | strip_newlines | replace: "'", "&#39;" %}
<div
  class="section-what-we-do color-{{ section.settings.color_schema }} w-full {{ settings.reveal_animation_class }}"
  id="section-{{ section.id }}"
  x-data="section({{ section.settings | json | escape }})"
  :class="classes"
>
  <div class="{{ section.settings.container_type }}">
    <div id="react-data" data-injected-props='{{ data }}'></div>
    {% render 'react-block', name: "theme__what-we-do", props: data %}
  </div>
</div>

{% schema %}
{
  "name": "What We Do",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 60
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "What We Do"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Helping learners master real world driving skills"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We provide professional driving training designed to help learners become safe, confident, and responsible drivers. Our programs combine classroom knowledge with hands-on road practice."
    },
    {
      "type": "header",
      "content": "Right side"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact button text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact URL"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video / Play button URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container type",
      "default": "container",
      "options": [
        { "value": "container", "label": "Use container width" },
        { "value": "w-full", "label": "Use full width" }
      ]
    },
    {
      "type": "header",
      "content": "Padding & Alignment settings"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_left_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_left_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Mobile",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Feature card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon (default)",
          "default": "steering",
          "info": "Used when no custom image is set.",
          "options": [
            { "value": "steering", "label": "Steering / Driving" },
            { "value": "book", "label": "Book" },
            { "value": "folder", "label": "Folder" }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom icon image",
          "info": "Optional. If set, this image is used instead of the default icon above."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What We Do",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "steering",
            "title": "Advanced Driving Skills",
            "description": "We teach the fundamentals of driving, including steering control, braking, gear shifting, and road awareness."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "book",
            "title": "Beginner Driving Training",
            "description": "We teach the fundamentals of driving, including steering control, braking, gear shifting, and road awareness."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "folder",
            "title": "License Test Preparation",
            "description": "We teach the fundamentals of driving, including steering control, braking, gear shifting, and road awareness."
          }
        }
      ]
    }
  ]
}
{% endschema %}

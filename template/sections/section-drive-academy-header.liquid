{% capture custom_data %}
{
  "section": {
    "logo_text": "{{ section.settings.logo_text | escape }}",
    "cta_text": "{{ section.settings.cta_text | escape }}",
    "cta_url": "{{ section.settings.cta_url | escape }}",
    "sticky": {% if section.settings.sticky_header %}true{% else %}false{% endif %},
    "show_cart": {% if section.settings.show_cart %}true{% else %}false{% endif %},
    "cart_count": {{ cart.item_count | default: 0 }}
  },
  "links": [
    {% if section.settings.menu != blank %}
    {% assign menu_links = linklists[section.settings.menu].links %}
    {% for link in menu_links %}
    {
      "title": "{{ link.title | escape }}",
      "url": "{{ link.url | escape }}",
      "children": [
        {% for child in link.links %}
        { "title": "{{ child.title | escape }}", "url": "{{ child.url | escape }}" }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
    {% endif %}
  ]
}
{% endcapture %}
{% assign data = custom_data | strip_newlines | replace: "'", "&#39;" %}
<div
  class="section-drive-academy-header header-container color-{{ section.settings.color_schema }} w-full {{ settings.reveal_animation_class }}"
  id="section-{{ section.id }}"
  x-data="section({{ section.settings | json | escape }})"
  :class="classes"
>
  <div class="header react-node">
    <div class="{{ section.settings.container_type }} relative">
      <div id="react-data" data-injected-props='{{ data }}'></div>
      {% render 'react-block', name: "theme__drive-academy-header", props: data %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Drive Academy Header",
  "tag": "header",
  "class": "section-header sticky top-0 z-30",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image",
      "info": "Optional. If set, image is shown instead of text."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo / Brand name (fallback when no image)",
      "default": "Autoguru"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Enroll Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Show cart icon",
      "default": true
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container type",
      "default": "container",
      "options": [
        { "value": "container", "label": "Use container width" },
        { "value": "w-full", "label": "Use full width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Padding & Alignment settings"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_left_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Mobile",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Drive Academy Header"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}

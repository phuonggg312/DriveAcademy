<div
  class="section-featured-collections color-{{ section.settings.color_schema  }}"
  x-data="section({{ section.settings | json | escape }})"
  :class="classes"
>
  <div class="{{ section.settings.container_type }}">
    <div class="react-node">
      {% include 'react-props' %}
      <div
              id="react-data"
              data-injected-props='{{ data }}'
      ></div>
      {% render 'react-block', name: "theme__featured-collections", props: data %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "select",
      "id": "render_type",
      "options": [
        {
          "value": "all",
          "label": "All"
        },
        {
          "value": "mobile-only",
          "label": "Mobile Only"
        },
        {
          "value": "desktop-only",
          "label": "Desktop Only"
        }
      ],
      "default": "desktop-only",
      "label": "Render Type",
      "info": "This will display this block based on Desktop, Mobile or both."
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container Type",
      "default": "container",
      "info": "Contained: Maximum width(Theme settings > Layout > Container Width) ",
      "options": [
        {
          "label": "Contained",
          "value": "container"
        },
        {
          "label": "Full Width",
          "value": ""
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Container Colour Scheme",
      "info": "Container background, header heading & description colour"
    },
    {
      "type": "header",
      "content": "Section Header Settings"
    },
    {
      "type": "number",
      "id": "header_max_width",
      "label": "Header Max Width",
      "default": 750,
      "info": "Max 2000"
    },
    {
      "type": "range",
      "id": "header_margin_bottom",
      "label": "Header Margin Bottom - Desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "header_margin_bottom_mobile",
      "label": "Header Margin Bottom - Mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header Alignment",
      "default": "items-center text-center",
      "options": [
        {
          "label": "Left",
          "value": "items-start text-left"
        },
        {
          "label": "Center",
          "value": "items-center text-center"
        },
        {
          "label": "Right",
          "value": "items-end text-right"
        }
      ]
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "heading_type",
      "label": "Heading Type - Desktop",
      "info": "Theme settings > Typography > Headings",
      "default": "h2"
    },
    {
      "type": "text",
      "id": "heading_type_mobile",
      "label": "Heading Type - Mobile",
      "info": "Theme settings > Typography > Headings",
      "default": "h4"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "body_type",
      "label": "Description Body Type - Desktop",
      "info": "Theme settings > Typography > Body",
      "default": "b3"
    },
    {
      "type": "text",
      "id": "body_type_mobile",
      "label": "Description Body Type - Mobile",
      "info": "Theme settings > Typography > Body",
      "default": "b3"
    },
    {
      "type": "header",
      "content": "Tabs Settings"
    },
    {
      "type": "color_scheme",
      "id": "nav_color_schema",
      "label": "Tab Navigation Color Scheme",
      "info": "Button text, background and hover colors"
    },
    {
      "type": "checkbox",
      "id": "enable_all",
      "label": "Enable All Collections ?",
      "info": "If checked, All Collections tab will be added with collections from all of the tabs",
      "default": true
    },
    {
      "type": "text",
      "id": "all_collections_label",
      "label": "All Collections Tab Label",
      "default": "All Collections"
    },
    {
      "type": "text",
      "id": "show_more",
      "label": "Show More Button Label",
      "default": "Show More"
    },
    {
      "type": "header",
      "content": "Collection Column Settings"
    },
    {
      "type": "color_scheme",
      "id": "column_color_schema",
      "label": "Column Color scheme",

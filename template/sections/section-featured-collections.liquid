      "step": 1,
      "unit": "px",
      "label": "Content Bottom Inner Padding - Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "content_padding_left_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Content Left Inner Padding - Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "content_padding_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,

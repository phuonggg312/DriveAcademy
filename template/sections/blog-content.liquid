<style>
  .section-blog-content h1,
  .section-blog-content h2,
  .section-blog-content h3,
  .section-blog-content h4,
  .section-blog-content h5,
  .section-blog-content h6
  {
    margin-bottom: {{ section.settings.title_margin_bottom }}px;
  }

  .section-blog-content ol,
  .section-blog-content ul
  {
    margin-bottom: {{ section.settings.list_margin_bottom }}px;
    list-style-position: inside;
  }

  .section-blog-content p
  {
    margin-bottom: {{ section.settings.paragraph_margin_bottom }}px;
  }

  .section-blog-content img
  {
    margin-bottom: {{ section.settings.image_margin_bottom }}px;
  }
</style>

<div class="section-blog-content {{ section.settings.custom_class }} color-{{ section.settings.color_schema }}">
  <div class="section-blog-content-{{ section.id }} relative {{ settings.reveal_animation_class }}"
       x-data="section({{ section.settings | json | escape }})"
       :class="classes"
  >
    <div class="{{ section.settings.container_type }} overflow-hidden relative w-full flex flex-col">
        {{ article.content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Blog Content",
  "class": "blog-content",
  "settings": [
    {
      "type": "header",
      "content": "Rendering settings"
    },
    {
      "type": "select",
      "id": "render_type",
      "options": [
        {
          "value": "all",
          "label": "All"
        },
        {
          "value": "mobile-only",
          "label": "Mobile Only"
        },
        {
          "value": "desktop-only",
          "label": "Desktop Only"
        }
      ],
      "default": "all",
      "label": "Render Type",
      "info": "This will display this block based on Desktop, Mobile or both."
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container type",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "Use container width"
        },
        {
          "value": "w-full",
          "label": "Use full width"
        }
      ],
      "info": "This will set the width of the section."
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Color scheme",
      "info": "This will change the color scheme of the section."
    },
    {
      "type": "checkbox",
      "id": "show_section_borders",
      "label": "Show Section Borders",
      "default": false,
      "info": "This will show borders around the section."
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom Class",
      "info": "This will add a custom class to the section. (Useful for custom styling)"
    },

    {
      "type": "header",
      "content": "Text Margins",
      "info": "These settings will help you to adjust the padding and alignment of the section."
    },
    {
      "type": "range",
      "id": "title_margin_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Title Margin Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "paragraph_margin_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Paragraph Margin Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "list_margin_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "List Margin Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "image_margin_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Image Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding & Alignment settings",
      "info": "These settings will help you to adjust the padding and alignment of the section."
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left & Right Mobile",
      "default": 0
    },
    {
      "type": "header",
      "content": "CLS / Performance"
    },
    {
      "type": "number",
      "id": "desktop_min_height",
      "label": "Min height (Desktop)",
      "default": 0,
      "info": "Set a minimum height for the section. This can help prevent layout shifts when the content loads."
    },
    {
      "type": "number",
      "id": "mobile_min_height",
      "label": "Min height (Mobile)",
      "default": 0,
      "info": "Set a minimum height for the section. This can help prevent layout shifts when the content loads."
    }
  ],
  "enabled_on": {
    "templates": ["article"]
  },
  "presets": [
    {
      "name": "Blog Content"
    }
  ]
}
{% endschema %}

  "scripts": {
    "build": "pnpm vite:build",
    "build-prod": "pnpm vite:build && rm -rf ./assets/.vite/",
    "watch": "pnpm build-dev --watch",
    "nodemon-watch": "nodemon --signal SIGKILL --watch .yalc --exec pnpm vite:watch --force --no-open",
    "vite:watch": "cross-env NODE_ENV=development vite",
    "vite:build": "cross-env NODE_ENV=production vite build",
    "shopify:dev": "shopify theme dev --live-reload off --notify /tmp/theme.update --theme-editor-sync -e development",
    "shopify:uat": "shopify theme dev --live-reload hot-reload --notify /tmp/theme.update --theme-editor-sync -e staging ",
    "shopify:uat-no-config": "shopify theme dev --live-reload hot-reload --ignore=\"*.json\" --notify /tmp/theme.update --theme-editor-sync -e staging",
    "shopify:preview": "shopify theme dev --live-reload hot-reload --notify /tmp/theme.update --theme-editor-sync -e preview",
    "shopify:pull": "shopify theme pull",
    "shopify:push-live": "run-s vite:build && shopify theme push --live",
    "shopify:pull-dev": "shopify theme pull -d",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "npx chromatic --project-token=chpt_47f06c81e194993"
  }

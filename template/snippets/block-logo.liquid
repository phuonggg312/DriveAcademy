<div class="react-node">
    {% capture data %}
        {
            "id": "{{ block.id }}",
            "block_settings": {{ block.settings | json }},
            "section_settings": {{ section.settings | json }},
            "shop": {
                "name": "{{ shop.name }}"
            },
            "routes": {
                "root_url": "{{ routes.root_url }}"
            }
        }
    {% endcapture %}
    {% assign data = data %}
    <div id="react-data" data-injected-props='{{ data }}'></div>
    {% liquid render 'react-block', name: "theme__block-logo", props: data %}
</div>
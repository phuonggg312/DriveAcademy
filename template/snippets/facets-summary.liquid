{% comment %} Pills after filtes on filter type horizontal {% endcomment %}

{% assign filters_available = false %}
{% if results.filters %}

    <div class="active-facets active-facets-desktop flex space-x-2 my-4 items-center">
        {%- for filter in results.filters -%}

            {%- for value in filter.active_values -%}
                {% assign filters_available = true %}
                <facet-remove class="border border-gray-100 px-4 py-2 rounded-full text-xs shadow-sm">
                    <a href="{{ value.url_to_remove }}" class="active-facets__button active-facets__button--light">
                          <span class="active-facets__button-inner button button--tertiary inline">
                            {{ filter.label | escape }}: {{ value.label | escape }}
                              <div class="inline">
                                   {% render 'icons-website-actions', icon:'close-small', classes:'inline' %}
                              </div>
                            <span class="hidden">{{ 'products.facets.clear_filter' | t }}</span>
                          </span>
                    </a>
                </facet-remove>
            {%- endfor -%}

            {% if filter.type == 'price_range' %}
                {%- if filter.min_value.value != null or filter.max_value.value != null -%}
                    <facet-remove class="border border-gray-100 px-4 py-2 rounded-full text-xs shadow-sm">
                        <a href="{{ filter.url_to_remove }}" class="active-facets__button active-facets__button--light">
                                <span class="active-facets__button-inner button button--tertiary inline">
                                  {%- if filter.min_value.value -%}
                                      {{ filter.min_value.value | money }}
                                  {%- else -%}
                                      {{ 0 | money }}
                                  {%- endif -%}
                                  -
                                  {%- if filter.max_value.value -%}
                                      {{ filter.max_value.value | money }}
                                  {%- else -%}
                                      {{ filter.range_max | money }}
                                  {%- endif -%}
                                    {% render 'icons-website-actions', icon:'close-small',  classes: 'inline' %}
                                  <span class="hidden">{{ 'products.facets.clear_filter' | t }}</span>
                                </span>
                        </a>
                    </facet-remove>
                {%- endif -%}
            {% endif %}
        {%- endfor -%}


        {% if filters_available == true %}
            <facet-remove class="active-facets__button-wrapper">
                <a href="{{ results_url }}" class="active-facets__button-remove underlined-link">
                    <span>{{ 'products.facets.clear_all' | t }}</span>
                </a>
            </facet-remove>
        {% endif %}
    </div>
{% endif %}
{% style %}

    {% comment %} DARK BUTTON {% endcomment %}

    {% comment %} PRIMARY BUTTON {% endcomment %}
    {% assign button_scheme = settings.buttons_dark_color_scheme_primary %}

    .button-dark-primary {
    background: {% if button_scheme.settings.background_gradient != empty %}{{ button_scheme.settings.background_gradient }}{% else %}{{ button_scheme.settings.background }}{% endif %};
    color: {{ button_scheme.settings.button_text_color }};
    border-color: {{ button_scheme.settings.button_border_color }};

    {%- if button_scheme.settings.button_border_color == 'rgba(0,0,0,0)' -%}
        border-width: 0px;
    {%- endif -%}
    }

    .button-dark-primary:hover {
    background: {% if button_scheme.settings.background_gradient != empty %}{{ button_scheme.settings.background_gradient }}{% else %}{{ button_scheme.settings.hover_background_color }}{% endif %};
    color: {{ button_scheme.settings.hover_text_color }};
    border-color: {{ button_scheme.settings.hover_border_color }};

    {%- if button_scheme.settings.hover_border_color == 'rgba(0,0,0,0)' -%}
        border-width: 0px;
    {%- endif -%}
    }

    .button-dark-primary:active {
    background: {% if button_scheme.settings.background_gradient != empty %}{{ button_scheme.settings.background_gradient }}{% else %}{{ button_scheme.settings.active_background_color }}{% endif %};
    color: {{ button_scheme.settings.active_text_color }};
    border-color: {{ button_scheme.settings.active_border_color }};

    {%- if button_scheme.settings.active_border_color == 'rgba(0,0,0,0)' -%}
        border-width: 0px;
    {%- endif -%}
    }

    .button-dark-primary:disabled {
    background: {% if button_scheme.settings.background_gradient != empty %}{{ button_scheme.settings.background_gradient }}{% else %}{{ button_scheme.settings.disabled_background_color }}{% endif %};
    color: {{ button_scheme.settings.disabled_text_color }};
